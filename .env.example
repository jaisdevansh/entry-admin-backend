# ⚡ PRODUCTION ENVIRONMENT CONFIGURATION - ADMIN API
# Copy this file to .env and fill in your actual values

# ── Server Configuration ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3002

# ── Database Configuration ────────────────────────────────────────────────────
# MongoDB Atlas connection string (SAME as user-api)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# ── Security Configuration ────────────────────────────────────────────────────
# CRITICAL: Use SAME secrets as user-api for token compatibility
JWT_SECRET=your_super_secure_jwt_secret_here_256_bits_minimum
JWT_REFRESH_SECRET=your_different_refresh_secret_here_256_bits_minimum
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS Configuration ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (NO SPACES)
ALLOWED_ORIGINS=https://admin.yourdomain.com,https://host.yourdomain.com

# ── Redis Configuration (Optional but Recommended) ────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password
REDIS_TLS=false

# ── Firebase Configuration ────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# ── Cloudinary Configuration ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Twilio Configuration (SMS/OTP) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid
TWILIO_PHONE_NUMBER=+1234567890
# Set to 'false' for production (real SMS), 'true' for testing (DB OTP with hint)
TWILIO_BYPASS=true

# ── Payment Gateway Configuration ─────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Rate Limiting Configuration ───────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=2000

# ── Monitoring & Logging (Optional) ───────────────────────────────────────────
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info

# ── Cache Configuration ───────────────────────────────────────────────────────
CACHE_TTL_SHORT=30
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=3600

# ── Performance Configuration ─────────────────────────────────────────────────
MAX_POOL_SIZE=50
SOCKET_TIMEOUT_MS=45000
SERVER_SELECTION_TIMEOUT_MS=5000

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_CACHING=true
ENABLE_RATE_LIMITING=true
ENABLE_COMPRESSION=true
ENABLE_HELMET=true
